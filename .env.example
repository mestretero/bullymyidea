# ── Supabase ─────────────────────────────────────────────────────
# Public — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ─────────────────────────────────────────────────────────
# Used for sitemap, robots.txt, OG image absolute URLs, password reset link.
NEXT_PUBLIC_SITE_URL=https://bullymyidea.com

# ── Security ─────────────────────────────────────────────────────
# Random 32+ char string. Required in production — startup throws if missing.
RATE_LIMIT_SALT=replace-with-a-long-random-string

REVALIDATE_SECRET=your_revalidate_secret
